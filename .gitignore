# Python
__pycache__/
*.py[cod]
*.pyo
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
venv/
.venv/
env/
.env/

# Environment variables / secrets
.env
.env.local

# Dash / Flask cache
.cache/
flask_session/

# Local PGN cache of the last successful Sync (the Lichess Studies are the
# source of truth — ADR 0001). Never commit game data.
games.pgn
*.pgn
# Exception: the frozen Study snapshot that pairs with tests/data/uscf/
# games.json — the matching engine's ground truth (issue #28). It is a test
# fixture captured once, not a cache.
!tests/data/uscf/*.pgn
# Exception: captured analysed-Game fixtures for the engine-analysis suite
# (issue #57) — real Lichess computer analysis, captured once, not a cache.
!tests/data/*.pgn

# Local USCF response cache (enrichment, never a source of truth — ADR 0003)
uscf_cache.json

# Local engine-analysis AI-summary cache (never a source of truth — ADR 0004)
analysis_cache.json

# Per-user disposable caches (issue #72 [G2], ADR 0005): one subdir per user.
# Never a source of truth; never commit a user's game/USCF/coach data.
.user-data/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

